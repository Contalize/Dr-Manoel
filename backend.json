
{
  "collections": {
    "users": {
      "description": "Perfis de usuários do sistema com RBAC.",
      "fields": {
        "email": { "type": "string" },
        "role": { "type": "string", "description": "ADMIN ou PHARMACIST" },
        "name": { "type": "string" },
        "crm": { "type": "string", "description": "Registro profissional se aplicável" }
      }
    },
    "patients": {
      "description": "Perfis clínicos de pacientes (Conforme LGPD).",
      "fields": {
        "name": { "type": "string", "description": "Nome completo" },
        "email": { "type": "string" },
        "cpf": { "type": "string", "description": "CPF (Criptografado em repouso)" },
        "phone": { "type": "string" },
        "birthDate": { "type": "string" },
        "chronoAge": { "type": "number" },
        "bioAge": { "type": "number" },
        "gender": { "type": "string" },
        "status": { "type": "string" },
        "lgpdConsent": { "type": "boolean" },
        "consentDate": { "type": "string" },
        "lastConsultation": { "type": "string" },
        "medicationHistory": { "type": "array", "description": "Histórico de medicamentos salvos" }
      }
    },
    "medicamentos_referencia": {
      "description": "Base mestra de medicamentos sincronizada (ANVISA/Integrativa).",
      "fields": {
        "nome_comercial": { "type": "string" },
        "principio_ativo": { "type": "string" },
        "concentracao": { "type": "string" },
        "categoria": { "type": "string", "description": "Alopático, Fitoterápico, Suplemento" },
        "bula_resumida": { "type": "string" },
        "url_bula_anvisa": { "type": "string" },
        "contraindicacoes": { "type": "array" },
        "updated_at": { "type": "timestamp" }
      }
    },
    "audit_logs": {
      "description": "Trilha de auditoria para conformidade LGPD.",
      "fields": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "patientId": { "type": "string" },
        "timestamp": { "type": "timestamp" },
        "metadata": { "type": "object" }
      }
    },
    "anamnesis": {
      "description": "Registros de avaliação SOAP.",
      "fields": {
        "patientId": { "type": "string" },
        "subjective": { "type": "object" },
        "objective": { "type": "object" },
        "markers": { "type": "object" },
        "assessment": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      }
    },
    "protocols": {
      "description": "Protocolos de tratamento integrativo.",
      "fields": {
        "patientId": { "type": "string" },
        "name": { "type": "string" },
        "rationale": { "type": "string" },
        "therapies": { "type": "array" },
        "createdAt": { "type": "timestamp" }
      }
    },
    "transactions": {
      "description": "Registros financeiros da clínica.",
      "fields": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "method": { "type": "string" },
        "date": { "type": "string" }
      }
    }
  }
}
