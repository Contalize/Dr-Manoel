
{
  "collections": {
    "users": {
      "description": "Perfis de usuários do sistema com RBAC.",
      "fields": {
        "email": { "type": "string" },
        "role": { "type": "string", "description": "ADMIN ou PHARMACIST" },
        "name": { "type": "string" },
        "crm": { "type": "string", "description": "Registro profissional se aplicável" }
      }
    },
    "patients": {
      "description": "Perfis clínicos de pacientes (Conforme LGPD).",
      "fields": {
        "name": { "type": "string", "description": "Nome completo" },
        "email": { "type": "string" },
        "cpf": { "type": "string", "description": "CPF (Criptografado em repouso via lógica de app)" },
        "phone": { "type": "string" },
        "birthDate": { "type": "string" },
        "chronoAge": { "type": "number" },
        "bioAge": { "type": "number" },
        "gender": { "type": "string" },
        "status": { "type": "string" },
        "lgpdConsent": { "type": "boolean", "description": "Consentimento explícito coletado" },
        "consentDate": { "type": "string" },
        "lastConsultation": { "type": "string" }
      }
    },
    "medications": {
      "description": "Base de dados curada de medicamentos e fitoterápicos.",
      "fields": {
        "name": { "type": "string" },
        "activeIngredient": { "type": "string" },
        "category": { "type": "string" },
        "contraindications": { "type": "array" },
        "leaflets": { "type": "string" }
      }
    },
    "audit_logs": {
      "description": "Trilha de auditoria para conformidade LGPD.",
      "fields": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "action": { "type": "string" },
        "patientId": { "type": "string" },
        "timestamp": { "type": "timestamp" },
        "metadata": { "type": "object" }
      }
    },
    "anamnesis": {
      "description": "Registros de avaliação SOAP.",
      "fields": {
        "patientId": { "type": "string" },
        "subjective": { "type": "object" },
        "objective": { "type": "object" },
        "markers": { "type": "object" },
        "assessment": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      }
    },
    "protocols": {
      "description": "Protocolos de tratamento integrativo.",
      "fields": {
        "patientId": { "type": "string" },
        "name": { "type": "string" },
        "rationale": { "type": "string" },
        "therapies": { "type": "array" },
        "createdAt": { "type": "timestamp" }
      }
    },
    "transactions": {
      "description": "Registros financeiros da clínica.",
      "fields": {
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "method": { "type": "string" },
        "date": { "type": "string" }
      }
    }
  }
}
