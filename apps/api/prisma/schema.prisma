generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  ADMIN
  DOCTOR
  RECEPTIONIST
  PHARMACIST
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  document  String   @unique // CNPJ ou CPF principal da clínica
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  patients Patient[]
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         Role
  
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id])

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? 
}

model Patient {
  id        String    @id @default(uuid())
  fullName  String
  document  String    // CPF ou CNPJ
  type      String    // PF ou PJ
  email     String?
  phone     String?

  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([document, tenantId])
}
