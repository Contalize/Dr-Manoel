rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regra de Meio-Termo: Permite acesso total para qualquer usuário autenticado.
    // Isso evita o erro de permissão em documentos que ainda não possuem o campo 'userId'.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}