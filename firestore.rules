rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite leitura e escrita temporariamente para facilitar o desenvolvimento e testes iniciais.
    // Em produção, estas regras devem ser restritas com 'if request.auth != null'.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}